{
  "id": "sale",
  "name": "Sale Sharks",
  "shortName": "SAL",
  "color": "#0a1b40",
  "secondaryColor": "#ffffff",
  "stadium": "Salford Community Stadium (formerly AJ Bell Stadium)",
  "nickname": "Sharks",
  "founded": 1861,
  "stadiumCapacity": 12000,
  "headCoach": "Alex Sanderson (Director of Rugby since 2021)",
  "honours": "Premiership title 2005-06; European Challenge Cup 2001-02, 2004-05",
  "blurb": "The Manchester defence-first side: line-speed, collision-dominant loose forwards and a physical inside-centre channel, all built to choke teams into errors. Sale are happy to cede possession because they back their defence to win the field-position battle, and George Ford's tempo control gives them clinical execution when they do attack. Tackles, turnovers and territory underpin everything; they are the league's least flashy and most resilient team. Box-kick, chase, tackle, repeat.",
