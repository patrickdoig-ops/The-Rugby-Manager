    "attackingGamePlan": "possession",
    "attackingStyle": "wide_wide",
    "attackingBreakdown": "wide_play",
    "defendingBreakdown": "jackal",
    "backfieldDefence": "one_back"
  },
  "statBias": [
    "pace",
    "agility",
    "handling"
  ],
  "stars": [
    {
      "name": "Marcus Smith",
      "position": "Fly-half",
      "nationality": "England",
      "blurb": "England fly-half and British & Irish Lion; the creative fulcrum of the Quins attack with electric footwork at first receiver, cross-field-kick threat, and late drop-goal nous. The heartbeat of the league's most expansive side",
