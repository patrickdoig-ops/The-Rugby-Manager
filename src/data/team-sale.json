    "attackingGamePlan": "kicking",
    "attackingStyle": "keep_it_tight",
    "attackingBreakdown": "balanced",
    "defendingBreakdown": "shadow",
    "backfieldDefence": "one_back",
    "defensiveLine": "blitz"
  },
  "statBias": [
    "tackling",
    "strength",
    "kicking"
  ],
  "stars": [
    {
      "name": "Tom Curry",
      "position": "Flanker",
      "nationality": "England",
      "blurb": "Lions Test starter at openside on the 2025 Australia tour; relentless jackal threat and the \"engine\" of England's back row, with brutal tackle work-rate even after wrist surgery",
