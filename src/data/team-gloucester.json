{
  "id": "gloucester",
  "name": "Gloucester",
  "shortName": "GLO",
  "color": "#c8102e",
  "secondaryColor": "#ffffff",
  "stadium": "Kingsholm Stadium (the famous \"Shed\" terrace)",
  "blurb": "A historic west-country club with a cherry-and-white forwards-led identity, defined by the close, vocal \"Shed\" at Kingsholm. Gloucester traditionally make their living from a robust, hard-carrying pack, set-piece confrontation and direct lines through the middle. The backline is functional rather than expansive, leaning on power runners to punch holes that fast support can exploit. At their best they are abrasive, physical and uncompromising at the breakdown; at their worst they over-rely on the forwards when a wider game is needed.",
  "suggestedTactics": {
    "attackingGamePlan": "balanced",
    "attackingStyle": "keep_it_tight",
    "attackingBreakdown": "pick_and_drive",
    "defendingBreakdown": "counter_ruck",
    "backfieldDefence": "one_back"
  },
  "statBias": [
    "strength",
    "breakdown",
    "setPiece"
  ],
